# ============================================================
# Telegram ↔ Claude Code Bridge — 配置示例
#
# 把这个文件复制成 .env 再填真实值：
#   cp .env.example .env
#   chmod 600 .env
# ============================================================

# 从 @BotFather 申请新 bot 拿到的 token
TELEGRAM_BOT_TOKEN=1234567890:AAE_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 允许与 bot 对话的 Telegram user id（逗号分隔多个）
# 不知道自己 id? 先留一个占位数字（比如 0），启动后去 Telegram 给 bot 发 /start，
# bot 会回复 "unauthorized (your id: 123456789)" —— 把那个数字填进来。
ALLOWED_USER_IDS=123456789

# claude 子进程启动时的工作目录（决定 CLAUDE.md 查找范围、文件操作起点）
# 推荐专用目录：CLAUDE_CWD=~/claude-tg-bot/workspace
CLAUDE_CWD=~/

# claude 可执行文件的绝对路径
# 用 `which claude` 查，常见位置：
#   - npm 全局安装: ~/.npm-global/bin/claude 或 /usr/local/bin/claude
#   - 官方安装器:   ~/.local/bin/claude
CLAUDE_BIN=/home/YOUR_USER/.local/bin/claude

# 空闲会话回收时间（秒）。超过这么久没发消息，对应 chat 的 claude 子进程会被杀
# 掉以释放内存。下次再发消息自动重启（冷启动，上下文丢失）。
IDLE_TIMEOUT_SECONDS=1800

# 最多同时活跃多少个 chat 的 claude 子进程。超过会驱逐最久没用的那个。
# 每个 claude 子进程占用约 200MB 内存 + 一定 CPU，按机器配置调整。
MAX_SESSIONS=5
